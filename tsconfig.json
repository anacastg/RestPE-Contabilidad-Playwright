{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@config/*": ["config/*"],
      "@utils/*": ["utils/*"],
      "@pages/*": ["pages/*"],
      "@components/*": ["components/*"],
      "@data/*": ["data/*"],
      "@fixtures/*": ["fixtures/*"],
      "@tipos/*": ["types/*"],
      "@constants/*": ["constants/*"],
      "@selectors/*": ["selectors/*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "playwright-report",
    "exploracion-output",
    "test-results"
  ]
}
